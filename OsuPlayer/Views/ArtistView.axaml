<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:OsuPlayer.Views"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:interfaces="clr-namespace:OsuPlayer.Data.DataModels.Interfaces;assembly=OsuPlayer.Data"
             xmlns:customControls="clr-namespace:OsuPlayer.Views.CustomControls"
             xmlns:classes="clr-namespace:OsuPlayer.Data.OsuPlayer.Classes;assembly=OsuPlayer.Data"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="OsuPlayer.Views.ArtistView"
             x:DataType="views:ArtistViewModel"
             FontWeight="{DynamicResource DefaultFontWeight}"
             SizeChanged="ArtistView_SizeChanged">

  <Design.DataContext>
    <views:ArtistViewModel />
  </Design.DataContext>

  <ScrollViewer Container.Name="artistView" Container.Sizing="Width">
    <ScrollViewer.Styles>
      <!-- Default font size (wide) -->
      <Style Selector="TextBlock#ArtistNameText">
        <Setter Property="FontSize" Value="64" />
      </Style>
      <ContainerQuery Name="artistView" Query="max-width:1199">
        <Style Selector="TextBlock#ArtistNameText">
          <Setter Property="FontSize" Value="48" />
        </Style>
      </ContainerQuery>
      <ContainerQuery Name="artistView" Query="max-width:899">
        <Style Selector="TextBlock#ArtistNameText">
          <Setter Property="FontSize" Value="36" />
        </Style>
      </ContainerQuery>
      <ContainerQuery Name="artistView" Query="max-width:799">
        <Style Selector="TextBlock#ArtistNameText">
          <Setter Property="FontSize" Value="48" />
        </Style>
      </ContainerQuery>
    </ScrollViewer.Styles>
    <StackPanel Margin="0 1">
      <!-- Artist header: rounded square image + name/back-button -->
      <Grid
      x:Name="ArtistHeaderGrid"
      ColumnDefinitions="256, *"
      Margin="16 12"
      ColumnSpacing="32"
      >
        <!-- Rounded square artist image (hidden until loaded) -->
        <Border x:Name="ArtistImageBorder"
                Grid.Column="0"
                Height="256"
                CornerRadius="20"
                ClipToBounds="True"
                HorizontalAlignment="Stretch"
                IsVisible="{Binding ArtistImage, Converter={x:Static ObjectConverters.IsNotNull}}"
                Margin="0 0 0 0"
                VerticalAlignment="Center">
          <Image Source="{Binding ArtistImage}"
                 Stretch="UniformToFill" />
        </Border>

        <!-- Name + back button -->
        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="8">
          <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Left">
            <Button
            Width="40" Height="40" CornerRadius="50"
            BorderThickness="1 1 0 0"
            Background="Transparent" Click="BackButton_Click"
            ToolTip.Tip="Go back">
              <avalonia:MaterialIcon Kind="ArrowLeft" Height="24" Width="24" />
            </Button>
            <Panel>
              <Button
              Name="AddToPlaylistButton" Width="40" Height="40" CornerRadius="50"
              Background="Transparent" Click="AddToPlaylistButton_Click"
              ToolTip.Tip="Add to playlist"
              BorderThickness="1 1 0 0"
              Padding="12 6 10 5"
              IsVisible="{Binding HasLastFmData}">
                <Panel>
                  <avalonia:MaterialIcon Kind="PlaylistEdit" Height="24" Width="24"
                                         IsVisible="{Binding IsInAnyPlaylist}" />
                  <avalonia:MaterialIcon Kind="PlaylistPlus" Height="24" Width="24"
                                         IsVisible="{Binding !IsInAnyPlaylist}" />
                </Panel>
              </Button>
              <Popup Placement="AnchorAndGravity"
                     PlacementTarget="{Binding ElementName=AddToPlaylistButton}"
                     Width="220" IsOpen="{Binding IsAddToPlaylistPopupOpen}"
                     IsLightDismissEnabled="True">
                <Border Background="{DynamicResource PopupBase}" CornerRadius="6" Padding="4">
                  <ItemsControl ItemsSource="{Binding PlaylistContextMenuEntries}">
                    <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="classes:AddToPlaylistContextMenuEntry">
                        <Button Background="Transparent" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Padding="10 6"
                                Click="PlaylistPopupItem_Click">
                          <Grid ColumnDefinitions="20, *">
                            <avalonia:MaterialIcon Grid.Column="0"
                                                   Kind="Check" Height="14" Width="14"
                                                   VerticalAlignment="Center"
                                                   IsVisible="{Binding IsFullyInPlaylist}"
                                                   Opacity="0.7" />
                            <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="13"
                                       Margin="4 0 0 0" VerticalAlignment="Center" />
                          </Grid>
                        </Button>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Border>
              </Popup>
            </Panel>
          </StackPanel>
          <StackPanel
          Orientation="Horizontal" Spacing="16"
          HorizontalAlignment="Left"
          VerticalAlignment="Center"
          >
            <TextBlock x:Name="ArtistNameText"
                       Text="{Binding ArtistName}"
                       FontWeight="Bold"
                       TextWrapping="Wrap" />

            <Border
            Background="Transparent"
            BorderBrush="{DynamicResource ButtonBorderBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="8 3 8 4"
            Margin="0 3 0 0"
            IsVisible="{Binding Tags, Converter={x:Static ObjectConverters.IsNotNull}}"
            VerticalAlignment="Center"
            >
              <TextBlock
              Text="{Binding Tags[0]}"
              FontSize="12"
              FontWeight="Light"
              Opacity="0.4"
              />
            </Border>
          </StackPanel>
        </StackPanel>

      </Grid>

      <!-- Loading indicator -->
      <TextBlock Text="Loading Last.fm data..." FontSize="13" Margin="20 10"
                 IsVisible="{Binding IsLoading}"
                 Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />

      <!-- Songs header -->
      <Border Margin="0 10 0 0" Padding="20 8">
        <TextBlock Text="Songs" FontSize="28" FontWeight="SemiBold" />
      </Border>

      <!-- Song list -->
      <!-- Empty state — shown when no songs exist for this artist -->
      <Border IsVisible="{Binding HasNoSongs}" Padding="20 12 20 20">
        <StackPanel Spacing="6" HorizontalAlignment="Center">
          <avalonia:MaterialIcon Kind="MusicOff" Width="40" Height="40"
                              HorizontalAlignment="Center"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
          <TextBlock TextAlignment="Center" FontSize="14" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextFillColorSecondaryBrush}">
            <Run Text="No songs found for " />
            <Run Text="{Binding ArtistName}" FontWeight="Bold"
                 Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
          </TextBlock>
          <TextBlock Text="Download songs in osu! to see them here."
                     TextAlignment="Center" FontSize="12"
                     Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
        </StackPanel>
      </Border>

      <ListBox x:Name="SongListBox"
               ItemsSource="{Binding Songs}" Background="Transparent"
               ScrollViewer.VerticalScrollBarVisibility="Disabled"
               ScrollViewer.HorizontalScrollBarVisibility="Disabled"
               Padding="20 0"
               >
        <ListBox.Styles>
          <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="4 0 24 0" />
            <Setter Property="CornerRadius" Value="9" />
          </Style>
          <!-- Suppress the default selection highlight -->
          <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
          </Style>
          <Style Selector="ListBoxItem:selected /template/ Rectangle#SelectionIndicator">
            <Setter Property="IsVisible" Value="False" />
          </Style>
          <Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ListBoxItemPointeroverBackground}" />
          </Style>
          <!-- Currently-playing item keeps its distinct styling -->
          <Style Selector="ListBoxItem.playing">
            <Setter Property="Background" Value="#28FFFFFF" />
          </Style>
          <Style Selector="ListBoxItem.playing:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#28FFFFFF" />
          </Style>
          <Style Selector="ListBoxItem.playing:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#28FFFFFF" />
          </Style>
          <Style Selector="ListBoxItem.playing:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#28FFFFFF" />
          </Style>
        </ListBox.Styles>
        <ListBox.ItemTemplate>
          <DataTemplate DataType="interfaces:IMapEntryBase">
            <Grid
            ColumnDefinitions="Auto, *, Auto"
            RowDefinitions="Auto"
            VerticalAlignment="Center"
            Tapped="SongItem_DoubleTapped"
            Cursor="Hand"
            Background="Transparent">
              <Border
              Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
              Width="64" Height="64"
              Margin="0 4 16 4"
              CornerRadius="8"
              ClipToBounds="True"
              IsVisible="{Binding $parent[ListBox].((views:ArtistViewModel)DataContext).DisplaySongListCovers}">
                <Panel>
                  <customControls:AsyncCoverImage
                  Width="64" Height="64"
                  CornerRadius="8"
                  Entry="{Binding .}" />
                  <customControls:MiniAudioVisualizerView
                  Width="64" Height="64"
                  Entry="{Binding .}" />
                </Panel>
              </Border>

              <TextBlock
              Grid.Row="0"
              Grid.Column="1"
              Text="{Binding TitleString}"
              FontSize="24"
              FontWeight="Medium"
              VerticalAlignment="Center"
              />

              <TextBlock
              Grid.Column="2"
              Grid.Row="0"
              Grid.RowSpan="2"
              Text="{Binding TotalTimeString}"
              FontSize="16"
              FontWeight="Medium"
              VerticalAlignment="Center" HorizontalAlignment="Center" />
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <!-- Similar Artists (only when Last.FM data available) -->
      <StackPanel IsVisible="{Binding SimilarArtists, Converter={x:Static ObjectConverters.IsNotNull}}"
                  Margin="0 10 0 20">
        <Border Padding="20 8">
          <TextBlock Text="Similar Artists" FontSize="20" FontWeight="SemiBold" />
        </Border>

        <ItemsControl
        ItemsSource="{Binding SimilarArtists}"
        Margin="20 4 8 4">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="views:SimilarArtistDisplayEntry">
              <Button Background="Transparent"
                      Click="SimilarArtist_Click" Padding="10 6" Margin="0 2 4 2"
                      Opacity="{Binding Opacity}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <avalonia:MaterialIcon Kind="AccountMusic"
                                         Height="18" Width="18"
                                         VerticalAlignment="Center" />
                  <TextBlock Text="{Binding Name}" FontSize="16"
                             FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
