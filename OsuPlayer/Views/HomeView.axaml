<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:OsuPlayer.Views"
             xmlns:interfaces="clr-namespace:OsuPlayer.Data.DataModels.Interfaces;assembly=OsuPlayer.Data"
             xmlns:classes="clr-namespace:OsuPlayer.Data.OsuPlayer.Classes;assembly=OsuPlayer.Data"
             xmlns:customControls="clr-namespace:OsuPlayer.Views.CustomControls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="OsuPlayer.Views.HomeView"
        x:DataType="views:HomeViewModel"
             FontWeight="{DynamicResource DefaultFontWeight}">

    <Design.DataContext>
        <views:HomeViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="*" ColumnDefinitions="50*, 50*" Background="Transparent">
        <!--Songs Grid-->
        <Grid Row="0" Column="0" ColumnSpan="2" RowDefinitions="Auto, *" Margin="0 1">
            <Border Grid.Row="0" Padding="8 24 8 12" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                <Grid ColumnDefinitions="*, Auto">
                    <TextBlock Grid.Column="0" Text="Your songs" FontSize="32" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="16 12 0 8" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="0 0 24 0">
                        <TextBlock Text="Sort by" Margin="0 0 4 0" VerticalAlignment="Center" FontSize="14" />
                        <ComboBox ItemsSource="{Binding SortingModes}"
                                  SelectedItem="{Binding SelectedSortingMode}"
                                  VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <ListBox Grid.Row="1" x:Name="SongListBox"
              Padding="8 0"
                     ItemsSource="{Binding SortedSongEntries}" Background="Transparent"
                     Tapped="InputElement_OnDoubleTapped" SelectedItem="{Binding SelectedSong}">

                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Margin" Value="0 2" />
                    </Style>
                    <!-- Suppress the default selection highlight -->
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                        <Setter Property="Background" Value="Transparent" />
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ Rectangle#SelectionIndicator">
                        <Setter Property="IsVisible" Value="False" />
                    </Style>
                    <Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                        <Setter Property="Background" Value="{DynamicResource ListBoxItemPointeroverBackground}" />
                    </Style>
                    <!-- Currently-playing item keeps its distinct styling -->
                    <Style Selector="ListBoxItem.playing">
                        <Setter Property="Background" Value="#28FFFFFF" />
                    </Style>
                    <Style Selector="ListBoxItem.playing:selected /template/ ContentPresenter#PART_ContentPresenter">
                        <Setter Property="Background" Value="#28FFFFFF" />
                    </Style>
                    <Style Selector="ListBoxItem.playing:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                        <Setter Property="Background" Value="#28FFFFFF" />
                    </Style>
                    <Style Selector="ListBoxItem.playing:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                        <Setter Property="Background" Value="#28FFFFFF" />
                    </Style>
                </ListBox.Styles>
                <ListBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Add to playlist"
                                  ItemsSource="{Binding PlaylistContextMenuEntries}"
                                  Classes="SubItems">
                            <MenuItem.Styles>
                                <Style Selector="MenuItem.SubItems MenuItem" x:CompileBindings="False">
                                    <Setter Property="Header" Value="{Binding Name}" />
                                    <Setter Property="Command" Value="{Binding AddToPlaylist}" />
                                    <Setter Property="CommandParameter" Value="{Binding Name}" />
                                </Style>
                            </MenuItem.Styles>
                        </MenuItem>
                        <MenuItem Header="Add to blacklist" Click="AddToBlacklist_OnClick" />
                    </ContextMenu>
                </ListBox.ContextMenu>
                <ListBox.DataTemplates>
                    <DataTemplate
                      DataType="interfaces:IMapEntryBase">
                        <Grid
                          Cursor="Hand"
                          ColumnDefinitions="Auto, *, 100"
                          RowDefinitions="Auto, Auto"
                          Background="Transparent">
                            <!-- Cover image with mini visualizer overlay -->
                            <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                                    Width="44" Height="44"
                                    Margin="0 0 10 0"
                                    CornerRadius="7"
                                    ClipToBounds="True"
                                    IsVisible="{Binding $parent[ListBox].((views:HomeViewModel)DataContext).DisplaySongListCovers}">
                                <Panel>
                                    <customControls:AsyncCoverImage
                                        Width="44" Height="44"
                                        CornerRadius="6"
                                        Entry="{Binding .}" />
                                    <customControls:MiniAudioVisualizerView
                                        Width="44" Height="44"
                                        Entry="{Binding .}" />
                                </Panel>
                            </Border>

                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TitleString}" FontSize="20" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ArtistString}"
                                       FontSize="14" Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                       FontWeight="{DynamicResource SmallerFontWeight}"/>

                            <Grid Row="0" RowSpan="2" Column="2" ColumnDefinitions="*">
                                <TextBlock Grid.Column="0" Text="{Binding TotalTimeString}"
                                           FontSize="20" FontWeight="{DynamicResource SmallerFontWeight}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </ListBox.DataTemplates>
            </ListBox>
            <StackPanel Grid.Row="1" IsVisible="{Binding SongsLoading}" IsEnabled="{Binding SongsLoading}"
                        VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
                <TextBlock Text="Songs loading... please wait" />
                <ProgressBar IsIndeterminate="True" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>