<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:OsuPlayer.Views"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:storageModels="clr-namespace:OsuPlayer.Data.OsuPlayer.StorageModels;assembly=OsuPlayer.Data"
             xmlns:interfaces="clr-namespace:OsuPlayer.Data.DataModels.Interfaces;assembly=OsuPlayer.Data"
             xmlns:customControls="clr-namespace:OsuPlayer.Views.CustomControls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="OsuPlayer.Views.PlaylistView"
             x:DataType="views:PlaylistViewModel"
             FontWeight="{DynamicResource DefaultFontWeight}">

  <Design.DataContext>
    <views:PlaylistViewModel />
  </Design.DataContext>

  <Grid ColumnDefinitions="260, 1, *">
    <Grid Column="0" Margin="0 1" RowDefinitions="auto, *, auto">
      <Border Grid.Row="0" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <TextBlock
        Text="Your Playlists"
        FontSize="32"
        FontWeight="Bold"
        Margin="16 24 4 8" VerticalAlignment="Center" HorizontalAlignment="Left" />
      </Border>

      <ListBox
      Grid.Row="1"
      Padding="16 8 16 4"
      SelectedItem="{Binding SelectedPlaylist}"
      ItemsSource="{Binding Playlists}">
        <ListBox.Styles>
          <Style Selector="ListBoxItem">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
          </Style>
        </ListBox.Styles>
        <ListBox.ItemTemplate>
          <DataTemplate DataType="storageModels:Playlist">
            <Grid
            ColumnDefinitions="Auto,*,Auto"
            Margin="10 4"
            Background="Transparent"
            Cursor="Hand"
            AttachedToVisualTree="PlaylistItemLoaded">
              <avalonia:MaterialIcon Grid.Column="0" Kind="MusicNoteEighth" Margin="0,0,10,0" />
              <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold"
                         VerticalAlignment="Center" Margin="0 10" />
              <Button Grid.Column="2" Name="PlayPlaylist" Height="30" Width="30" CornerRadius="30"
                      Click="PlayPlaylist_OnClick" Margin="0" VerticalAlignment="Center"
                      Background="Transparent">
                <avalonia:MaterialIcon Kind="PlayArrow" Height="20" Width="20" />
              </Button>
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <StackPanel
      HorizontalAlignment="Left"
      Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="16 8 16 24">
        <Button
        Content="playlist editor"
        Padding="12 4"
        VerticalContentAlignment="Center" HorizontalContentAlignment="Center" VerticalAlignment="Center"
        Click="OpenPlaylistEditor_OnClick" FontWeight="SemiBold"
        Background="Transparent"
        />

        <Button
        Content="blacklist"
        Padding="12 4"
        VerticalContentAlignment="Center" HorizontalContentAlignment="Center" VerticalAlignment="Center"
        Click="OpenBlacklistEditor_OnClick" FontWeight="SemiBold"
        Background="Transparent"
        />
      </StackPanel>
    </Grid>

    <GridSplitter Grid.Column="1" Background="Transparent" ResizeDirection="Columns"/>

    <Grid Column="2" Margin="1 1 0 1" RowDefinitions="Auto, *">
      <TextBox Grid.Row="0" Margin="10 32 16 24" Text="{Binding FilterText}" PlaceholderText="type to search..." />
      <ListBox Grid.Row="1" x:Name="SongListBox"
               Background="Transparent" ItemsSource="{Binding FilteredSongEntries}"
               SelectedItem="{Binding SelectedSong}">
        <ListBox.Styles>
          <!-- Suppress the default selection highlight -->
          <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
          </Style>
          <Style Selector="ListBoxItem:selected /template/ Rectangle#SelectionIndicator">
            <Setter Property="IsVisible" Value="False" />
          </Style>
          <Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ListBoxItemPointeroverBackground}" />
          </Style>
          <!-- Currently-playing item keeps its distinct styling -->
          <Style Selector="ListBoxItem.playing">
            <Setter Property="Background" Value="#28FFFFFF" />
          </Style>
          <Style Selector="ListBoxItem.playing:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#28FFFFFF" />
          </Style>
          <Style Selector="ListBoxItem.playing:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#28FFFFFF" />
          </Style>
          <Style Selector="ListBoxItem.playing:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#28FFFFFF" />
          </Style>
        </ListBox.Styles>
        <ListBox.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Remove from playlist" Click="MenuItem_OnClick" />
          </ContextMenu>
        </ListBox.ContextMenu>
        <ListBox.ItemTemplate>
          <DataTemplate DataType="interfaces:IMapEntryBase">
            <Grid
            ColumnDefinitions="Auto, *, Auto"
            RowDefinitions="Auto, Auto"
            Tapped="PlaySong"
            Margin="8 2"
            Cursor="Hand"
            Background="Transparent">
              <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                      Width="44" Height="44"
                      Margin="0 0 10 0"
                      CornerRadius="6"
                      ClipToBounds="True"
                      IsVisible="{Binding $parent[ListBox].((views:PlaylistViewModel)DataContext).DisplaySongListCovers}">
                <Panel>
                  <customControls:AsyncCoverImage
                  Width="44" Height="44"
                  CornerRadius="6"
                  Entry="{Binding .}" />
                  <customControls:MiniAudioVisualizerView
                  Width="44" Height="44"
                  Entry="{Binding .}" />
                </Panel>
              </Border>

              <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TitleString}" FontSize="20"
                         FontWeight="SemiBold" />
              <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ArtistString}"
                         FontSize="14" Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" FontWeight="Medium" />

              <TextBlock Grid.Column="2" Grid.Row="0" Grid.RowSpan="2" Text="{Binding TotalTimeString}"
                         FontSize="20" FontWeight="{DynamicResource BiggerFontWeight}"
                         VerticalAlignment="Center" HorizontalAlignment="Center" />
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Grid>
  </Grid>
</UserControl>