<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:windows="clr-namespace:OsuPlayer.Windows"
        xmlns:ui="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
        xmlns:interfaces="clr-namespace:OsuPlayer.Data.DataModels.Interfaces;assembly=OsuPlayer.Data"
        xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="OsuPlayer.Windows.FluentAppWindow"
        x:DataType="windows:FluentAppWindowViewModel"
        Title="osu!player"
        WindowStartupLocation="CenterScreen"
        Opened="Window_OnOpened">

  <Window.Styles>
    <Style Selector="ui|FANavigationView /template/ SplitView#RootSplitView /template/ Panel#PART_PaneRoot">
      <Setter Property="Margin" Value="12,8,12,0" />
    </Style>
  </Window.Styles>

  <Design.DataContext>
    <windows:FluentAppWindowViewModel />
  </Design.DataContext>

  <Grid Name="MainGrid" RowDefinitions="Auto, *, Auto">
    <!-- Fancy Acrylic Background -->
    <Panel Grid.Row="0" Grid.RowSpan="2" IsVisible="{Binding IsNonLinuxOs}">
      <ExperimentalAcrylicBorder IsHitTestVisible="False" Material="{Binding PanelMaterial}" />
    </Panel>

    <!-- BackgroundImage of Song -->
    <ExperimentalAcrylicBorder Grid.Row="0" Grid.RowSpan="3" Material="{Binding PanelMaterial}" IsVisible="{Binding IsNonLinuxOs}">
      <Panel IsVisible="{Binding DisplayBackgroundImage}">
        <Image x:Name="BgPrevAcrylic" Opacity="0"
               VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Stretch="UniformToFill" />
        <Image x:Name="BgNewAcrylic" Opacity="0"
               VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Stretch="UniformToFill" />
      </Panel>
    </ExperimentalAcrylicBorder>

    <Border Grid.Row="0" Grid.RowSpan="3" IsVisible="{Binding IsLinuxOs}">
      <Panel IsVisible="{Binding DisplayBackgroundImage}">
        <Image x:Name="BgPrevLinux" Opacity="0"
               VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Stretch="UniformToFill" />
        <Image x:Name="BgNewLinux" Opacity="0"
               VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Stretch="UniformToFill" />
      </Panel>
    </Border>

    <!-- TitleBar Host -->
    <Grid Row="0" Name="TitleBarHost"
          ColumnDefinitions="Auto,Auto,*,Auto"
          Margin="0,12,0,0"
          Background="Transparent">
      <Image Margin="12 4"
             IsHitTestVisible="False"
             Source="/Resources/x96.ico"
             Width="18" Height="18"
             DockPanel.Dock="Left"
             Name="WindowIcon"
             RenderOptions.BitmapInterpolationMode="HighQuality">
        <Image.IsVisible>
          <OnPlatform Default="False">
            <On Options="Windows" Content="True" />
          </OnPlatform>
        </Image.IsVisible>
      </Image>

      <TextBlock Text="{Binding Title, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                 FontSize="12"
                 IsHitTestVisible="False"
                 VerticalAlignment="Center"
                 Grid.Column="1">
        <TextBlock.IsVisible>
          <OnPlatform Default="False">
            <On Options="Windows" Content="True" />
          </OnPlatform>
        </TextBlock.IsVisible>
      </TextBlock>

      <Border Grid.Column="2" Padding="6">
        <AutoCompleteBox Name="SearchBox"
                         MaxWidth="500"
                         MaxDropDownHeight="500"
                         PlaceholderText="Search songs (hit enter to play)" ItemsSource="{Binding SongList}"
                         FilterMode="ContainsOrdinal"
                         KeyUp="SearchBox_OnKeyUp"
                         SelectionChanged="SearchBox_OnSelectionChanged">
          <!-- wnd:AppWindow.AllowInteractionInTitleBar="True" -->
          <AutoCompleteBox.ItemTemplate>
            <DataTemplate x:DataType="interfaces:IMapEntryBase">
              <Panel>
                <Grid ColumnDefinitions="*, Auto">
                  <StackPanel Grid.Column="0" HorizontalAlignment="Left"
                              VerticalAlignment="Center">
                    <TextBlock Text="{Binding TitleString}" />
                    <TextBlock Text="{Binding ArtistString}"
                               Theme="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"/>
                  </StackPanel>

                  <TextBlock Grid.Column="1" Text="{Binding TotalTimeString}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                </Grid>

              </Panel>
            </DataTemplate>
          </AutoCompleteBox.ItemTemplate>
        </AutoCompleteBox>
      </Border>
    </Grid>

    <ui:FANavigationView
    Grid.Row="1"
    CompactPaneLength="60"
    OpenPaneLength="216"
    PaneDisplayMode="LeftCompact"
    Name="AppNavigationView"
    ItemInvoked="AppNavigationView_OnItemInvoked" IsSettingsVisible="False">
      <ui:FANavigationView.Resources>
        <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="Transparent" />
        <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent" />
        <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="Transparent" />
      </ui:FANavigationView.Resources>
      <ui:FANavigationView.MenuItems>
        <ui:FANavigationViewItem Content="Songs" Tag="HomeNavigation" IconSource="Audio" Cursor="Hand" />
        <ui:FANavigationViewItem Content="Artists" Tag="ArtistsNavigation" IconSource="People" Cursor="Hand" />
        <ui:FANavigationViewItem Content="Playlists" Tag="PlaylistNavigation" IconSource="Library" Cursor="Hand" />
      </ui:FANavigationView.MenuItems>
      <ui:FANavigationView.FooterMenuItems>
        <ui:FANavigationViewItem Content="Open Miniplayer" Tag="MiniplayerNavigation" IconSource="FullScreenMinimize" Cursor="Hand" />
        <ui:FANavigationViewItem Name="Settings" Content="Settings" Tag="SettingsNavigation" IconSource="Settings" Cursor="Hand" />
      </ui:FANavigationView.FooterMenuItems>
      <ui:FANavigationView.Content>
        <Border CornerRadius="20,0,0,20" ClipToBounds="True" Margin="0 16 0 0"
                Background="{DynamicResource BaseBrighterDarkTransparentColor}">
          <TransitioningContentControl Name="MainViewPanel" Content="{Binding MainView}"
                                       PageTransition="{x:Null}" />
        </Border>
      </ui:FANavigationView.Content>
    </ui:FANavigationView>

    <ContentControl Name="PlayerControlPanel" Grid.Row="2" Content="{Binding PlayerControl}" />

    <!-- Song Artwork Expanded Overlay -->
    <Panel Grid.Row="0" Grid.RowSpan="3" ZIndex="200"
           IsVisible="False"
           Name="ArtworkOverlayRoot">
      <!-- Dark backdrop — click to dismiss -->
      <Panel Name="ArtworkOverlayBackdrop" Background="#CC000000" />
      <!-- Centered artwork card -->
      <Panel Name="ArtworkOverlayContent" IsHitTestVisible="True">
        <Border
        Margin="120"
        VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
        >
          <Border
          VerticalAlignment="Center" HorizontalAlignment="Center"
          CornerRadius="32" ClipToBounds="True"
          BoxShadow="0 16 48 8 #CC000000">
            <Image Source="{Binding PlayerControl.CurrentSongImage}"
                   Stretch="Uniform" />
          </Border>
        </Border>
        <Button Name="ArtworkOverlayCloseButton"
                VerticalAlignment="Top" HorizontalAlignment="Right"
                Margin="0 12 16 0"
                Width="36" Height="36" CornerRadius="50"
                Background="#CC000000"
                Foreground="White">
          <avalonia:MaterialIcon Kind="Close" Width="18" Height="18" />
        </Button>
      </Panel>
    </Panel>

    <!-- Compact / miniplayer-mode overlay shown when the window is resized small -->
    <Grid Grid.Row="0" Grid.RowSpan="3" ZIndex="300"
          IsVisible="{Binding IsCompactMode}"
          RowDefinitions="35, Auto, Auto, *">

      <!-- Blurred album art background -->
      <Border Grid.Row="0" Grid.RowSpan="4">
        <Image Source="{Binding PlayerControl.CurrentSongImage}" Stretch="UniformToFill" />
      </Border>
      <Border Grid.Row="0" Grid.RowSpan="4" Background="{DynamicResource AcrylicBaseColor}" />

      <!-- Drag handle / restore button -->
      <Border Grid.Row="0" Background="Transparent" PointerPressed="CompactTopBar_PointerPressed" />
      <Button Grid.Row="0"
              HorizontalAlignment="Right" VerticalAlignment="Center"
              Margin="0 0 8 0"
              Width="28" Height="28" CornerRadius="50"
              Theme="{StaticResource TransparentButton}"
              Click="CompactRestore_Click">
        <avalonia:MaterialIcon Kind="ArrowExpand" Width="16" Height="16" />
      </Button>

      <!-- Song title / artist -->
      <StackPanel Grid.Row="1" HorizontalAlignment="Stretch">
        <TextBlock Margin="10 0" Text="{Binding PlayerControl.TitleText}"
                   HorizontalAlignment="Center" FontSize="18"
                   FontWeight="{DynamicResource BiggerFontWeight}"
                   TextTrimming="CharacterEllipsis" />
        <TextBlock Margin="10 0" Text="{Binding PlayerControl.ArtistText}"
                   FontWeight="{DynamicResource SmallerFontWeight}"
                   HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" />
      </StackPanel>

      <!-- Progress row -->
      <Grid Grid.Row="2" ColumnDefinitions="60,*,60">
        <TextBlock Text="{Binding PlayerControl.CurrentSongTime}"
                   VerticalAlignment="Center" Margin="8 0"
                   Grid.Column="0" FontSize="12" HorizontalAlignment="Center" />
        <Slider VerticalAlignment="Center"
                Maximum="{Binding PlayerControl.SongLength}"
                Value="{Binding PlayerControl.SongTime}"
                Margin="4 0" UseLayoutRounding="False" Grid.Column="1" />
        <TextBlock Text="{Binding PlayerControl.CurrentSongLength}"
                   VerticalAlignment="Center" Grid.Column="2"
                   Margin="8 0" FontSize="12" HorizontalAlignment="Center" />
      </Grid>

      <!-- Transport controls -->
      <Border Grid.Row="3" Background="{DynamicResource AcrylicBaseColor}" />
      <ContentControl Grid.Row="3" Content="{Binding AudioVisualizer}" />
      <DockPanel Grid.Row="3" VerticalAlignment="Center" HorizontalAlignment="Center">
        <Button Name="CompactRepeat" Width="38" Height="38" CornerRadius="50"
                Theme="{StaticResource TransparentButton}" Click="CompactSongControl">
          <avalonia:MaterialIcon Kind="{Binding PlayerControl.IsRepeating, Converter={StaticResource RepeatConverter}}"
                                 Height="19" Width="19" />
        </Button>
        <Button Name="CompactPrevious" Width="38" Height="38" CornerRadius="50"
                Theme="{StaticResource TransparentButton}" Click="CompactSongControl">
          <avalonia:MaterialIcon Kind="SkipBackward" Height="19" Width="19" />
        </Button>
        <Button Name="CompactPlayPause" Width="50" Height="50" CornerRadius="50" Margin="8 0"
                Click="CompactSongControl">
          <avalonia:MaterialIcon Kind="{Binding PlayerControl.IsPlaying, Converter={StaticResource PlayPauseConverter}}"
                                 Height="40" Width="40" />
        </Button>
        <Button Name="CompactNext" Width="38" Height="38" CornerRadius="50"
                Theme="{StaticResource TransparentButton}" Click="CompactSongControl">
          <avalonia:MaterialIcon Kind="SkipForward" Height="19" Width="19" />
        </Button>
        <Button Name="CompactShuffle" Width="38" Height="38" CornerRadius="50"
                Theme="{StaticResource TransparentButton}" Click="CompactSongControl">
          <avalonia:MaterialIcon Kind="{Binding PlayerControl.IsShuffle, Converter={StaticResource ShuffleConverter}}"
                                 Height="19" Width="19" />
        </Button>
      </DockPanel>
    </Grid>
  </Grid>

</Window>